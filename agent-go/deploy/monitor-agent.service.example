[Unit]
Description=CacheWraith Go Monitoring Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/monitor-agent.env
ExecStart=/usr/local/bin/monitor-agent --config /etc/monitor-agent/config.json
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
